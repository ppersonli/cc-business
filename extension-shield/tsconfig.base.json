{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@extension-shield/scanner": ["./packages/scanner/src/index.ts"],
      "@extension-shield/scanner/*": ["./packages/scanner/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}

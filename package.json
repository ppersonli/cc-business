{
  "name": "cc-business",
  "private": true,
  "workspaces": [
    "devtools-hub",
    "chrome-extension",
    "shared",
    "extension-shield/packages/*",
    "extension-shield/web"
  ],
  "scripts": {
    "dev:hub": "npm run dev --workspace=devtools-hub",
    "dev:ext": "npm run dev --workspace=chrome-extension",
    "dev:shield-ext": "pnpm --filter extension-shield-extension dev",
    "dev:shield-web": "pnpm --filter extension-shield-web dev",
    "build:hub": "npm run build --workspace=devtools-hub",
    "build:ext": "npm run build --workspace=chrome-extension",
    "build:shield": "pnpm --filter extension-shield-scanner build && pnpm --filter extension-shield-extension build && pnpm --filter extension-shield-web build",
    "test:shield": "pnpm --filter extension-shield-scanner test && pnpm --filter extension-shield-extension test"
  },
  "devDependencies": {
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
